"4	LINE	0
	cmake_minimum_required(VERSION 3.20)
	
	project(sw_shield C ASM)
	
	enable_language(C ASM)
	
	# ------------------------------------------------------------
	# Configuration gÃƒÂ©nÃƒÂ©rale
	# ------------------------------------------------------------
	set(TARGET_NAME sw_shield)
	
	if(NOT CMAKE_BUILD_TYPE)
	    set(CMAKE_BUILD_TYPE Debug)
	endif()
	
	set(CMAKE_C_STANDARD 11)
	set(CMAKE_C_STANDARD_REQUIRED ON)
	
	# ------------------------------------------------------------
	# MCU - A ADAPTER
	# Exemple H743 FPU hard
	# ------------------------------------------------------------
	set(MCU_FLAGS
	    -mcpu=cortex-m7
	    -mthumb
	    -mfpu=fpv5-d16
	    -mfloat-abi=hard
	)
	
	# ------------------------------------------------------------
	# Linker script - A ADAPTER
	# ------------------------------------------------------------
	set(LINKER_SCRIPT ${CMAKE_SOURCE_DIR}/STM32H743ZITX_FLASH.ld)
	
	# ------------------------------------------------------------
	# Sources - A ADAPTER
	# Mets ici toutes les sources du projet
	# ------------------------------------------------------------
	set(SOURCES
	    Core/Src/main.c
	    Core/Src/stm32h7xx_it.c
	    Core/Src/stm32h7xx_hal_msp.c
	    Core/Src/system_stm32h7xx.c
	
	    Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal.c
	    Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_rcc.c
	    Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_rcc_ex.c
	    Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_flash.c
	    Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_flash_ex.c
	    Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_gpio.c
